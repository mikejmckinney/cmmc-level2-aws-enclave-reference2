{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NIST 800-171 r2 control mapping row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "control_id",
    "family",
    "family_code",
    "control_name",
    "description",
    "addressed_by_repo",
    "aws_services",
    "terraform_resources",
    "requires_client_config",
    "organizational_control",
    "notes"
  ],
  "properties": {
    "control_id": {
      "type": "string",
      "pattern": "^3\\.(1[0-4]|[1-9])\\.(2[0-2]|1[0-9]|[1-9])$"
    },
    "family": {
      "type": "string",
      "enum": [
        "Access Control",
        "Awareness and Training",
        "Audit and Accountability",
        "Configuration Management",
        "Identification and Authentication",
        "Incident Response",
        "Maintenance",
        "Media Protection",
        "Personnel Security",
        "Physical Protection",
        "Risk Assessment",
        "Security Assessment",
        "System and Communications Protection",
        "System and Information Integrity"
      ]
    },
    "family_code": {
      "type": "string",
      "enum": ["AC", "AT", "AU", "CM", "IA", "IR", "MA", "MP", "PS", "PE", "RA", "CA", "SC", "SI"]
    },
    "control_name": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "addressed_by_repo": { "type": "string", "enum": ["full", "partial", "none"] },
    "aws_services": { "type": "string" },
    "terraform_resources": { "type": "string" },
    "requires_client_config": { "type": "string", "enum": ["true", "false"] },
    "organizational_control": { "type": "string", "enum": ["true", "false"] },
    "notes": { "type": "string" }
  }
}
